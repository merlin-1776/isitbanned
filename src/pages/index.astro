---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookCard from '../components/BookCard.astro';
import SearchBar from '../components/SearchBar.astro';
import HomeSchema from '../components/HomeSchema.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const books = (await getCollection('books')).sort(
	(a, b) => b.data.totalChallenges - a.data.totalChallenges
);

const searchBooks = books.map((b) => ({
	title: b.data.title,
	slug: b.data.slug,
	author: b.data.author,
	totalChallenges: b.data.totalChallenges,
	banReasons: b.data.banReasons,
	description: b.data.description,
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<HomeSchema />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Is your favorite book <span class="highlight">banned?</span></h1>
				<p class="hero-sub">Search thousands of banned and challenged books. Find out where, when, and why.</p>
				<SearchBar books={searchBooks} />
			</section>

			<section class="books-section">
				<h2>Most Challenged Books</h2>
				<div class="books-grid">
					{books.map((book) => (
						<BookCard
							title={book.data.title}
							slug={book.data.slug}
							author={book.data.author}
							totalChallenges={book.data.totalChallenges}
							banReasons={book.data.banReasons}
							description={book.data.description}
						/>
					))}
				</div>
				<div class="view-all">
					<a href={`${import.meta.env.BASE_URL}books/`}>View All Books →</a>
				</div>
			</section>
		</main>
		<Footer />
		<style>
			.hero {
				text-align: center;
				padding: 3em 0 4em;
			}
			.hero h1 {
				font-size: 3em;
				margin-bottom: 0.3em;
				line-height: 1.1;
			}
			.highlight {
				color: var(--accent);
				position: relative;
			}
			.hero-sub {
				font-size: 1.2rem;
				color: rgb(var(--gray));
				margin-bottom: 2em;
				max-width: 500px;
				margin-left: auto;
				margin-right: auto;
			}
			.books-section {
				padding: 2em 0;
			}
			.books-section h2 {
				text-align: center;
				margin-bottom: 1.5em;
				font-size: 2em;
			}
			.books-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.view-all {
				text-align: center;
				margin-top: 2em;
			}
			.view-all a {
				display: inline-block;
				padding: 0.75em 2em;
				background: var(--accent);
				color: #fff;
				text-decoration: none;
				border-radius: 8px;
				font-weight: 700;
				transition: background 0.2s;
			}
			.view-all a:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2em;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
