---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookCard from '../components/BookCard.astro';
import SearchBar from '../components/SearchBar.astro';
import HomeSchema from '../components/HomeSchema.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const books = (await getCollection('books')).sort(
	(a, b) => b.data.totalChallenges - a.data.totalChallenges
);

const searchBooks = books.map((b) => ({
	title: b.data.title,
	slug: b.data.slug,
	author: b.data.author,
	totalChallenges: b.data.totalChallenges,
	banReasons: b.data.banReasons,
	description: b.data.description,
}));

const homepageFeaturedBooks = books.slice(0, 24);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<HomeSchema />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Is your favorite book <span class="highlight">banned?</span></h1>
				<p class="hero-sub">Search thousands of banned and challenged books. Find out where, when, and why.</p>
				<SearchBar books={searchBooks} />
			</section>

			<div class="random-section">
				<button id="random-btn" class="random-btn">🎲 Random Banned Book</button>
			</div>

			<section class="featured-link-section">
				<a href={`/most-challenged-2025/`} class="featured-link-card">
					<span class="featured-kicker">New</span>
					<h2>ALA's Most Challenged Books of 2025</h2>
					<p>See the latest national list in one place, with direct links to every title.</p>
					<span class="featured-cta">View the 2025 list →</span>
				</a>
			</section>

			<section class="books-section">
				<h2>Most Challenged Books</h2>
				<div class="books-grid">
					{homepageFeaturedBooks.map((book) => (
						<BookCard
							title={book.data.title}
							slug={book.data.slug}
							author={book.data.author}
							totalChallenges={book.data.totalChallenges}
							banReasons={book.data.banReasons}
							description={book.data.description}
						/>
					))}
				</div>
				<div class="view-all">
					<a href={`/books/`}>View All Books →</a>
				</div>
			</section>
		</main>
		<Footer />
		<style>
			.hero {
				text-align: center;
				padding: 3em 0 4em;
			}
			.hero h1 {
				font-size: 3em;
				margin-bottom: 0.3em;
				line-height: 1.1;
			}
			.highlight {
				color: var(--accent);
				position: relative;
			}
			.hero-sub {
				font-size: 1.2rem;
				color: rgb(var(--gray));
				margin-bottom: 2em;
				max-width: 500px;
				margin-left: auto;
				margin-right: auto;
			}
			.random-section {
				text-align: center;
				margin-bottom: 2em;
			}
			.random-btn {
				display: inline-block;
				padding: 0.8em 2em;
				background: rgb(var(--gray-dark));
				color: #fff;
				border: none;
				border-radius: 8px;
				font-size: 1.1rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s;
			}
			.random-btn:hover {
				background: var(--accent);
				transform: scale(1.05);
			}
			.featured-link-section {
				margin: 0 auto 2em;
				max-width: 900px;
			}
			.featured-link-card {
				display: block;
				background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
				border: 2px solid #f3c7c7;
				border-radius: 14px;
				padding: 1.5em;
				text-decoration: none;
				color: inherit;
				transition: all 0.2s ease;
			}
			.featured-link-card:hover {
				border-color: var(--accent);
				box-shadow: 0 8px 24px rgba(220, 38, 38, 0.12);
				transform: translateY(-2px);
			}
			.featured-kicker {
				display: inline-block;
				margin-bottom: 0.6em;
				font-size: 0.75rem;
				font-weight: 800;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
			}
			.featured-link-card h2 {
				margin-bottom: 0.35em;
				text-align: left;
				font-size: 1.7em;
			}
			.featured-link-card p {
				margin: 0 0 0.6em 0;
				color: rgb(var(--gray-dark));
			}
			.featured-cta {
				font-weight: 700;
				color: var(--accent);
			}
			.books-section {
				padding: 2em 0;
			}
			.books-section h2 {
				text-align: center;
				margin-bottom: 1.5em;
				font-size: 2em;
			}
			.books-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.view-all {
				text-align: center;
				margin-top: 2em;
			}
			.view-all a {
				display: inline-block;
				padding: 0.75em 2em;
				background: var(--accent);
				color: #fff;
				text-decoration: none;
				border-radius: 8px;
				font-weight: 700;
				transition: background 0.2s;
			}
			.view-all a:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2em;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>

		<script>
			document.getElementById('random-btn')?.addEventListener('click', async () => {
				const res = await fetch('/slugs.json');
				const slugs = await res.json();
				const slug = slugs[Math.floor(Math.random() * slugs.length)];
				window.location.href = '/books/' + slug + '/';
			});
		</script>
	</body>
</html>
