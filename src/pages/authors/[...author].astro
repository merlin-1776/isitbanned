---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookCard from '../../components/BookCard.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

function slugify(name: string) {
	return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

export async function getStaticPaths() {
	const books = await getCollection('books');
	const authorMap = new Map<string, typeof books>();

	for (const book of books) {
		const authorSlug = book.data.author.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
		if (!authorMap.has(authorSlug)) {
			authorMap.set(authorSlug, []);
		}
		authorMap.get(authorSlug)!.push(book);
	}

	return Array.from(authorMap.entries()).map(([slug, books]) => ({
		params: { author: slug },
		props: {
			authorName: books[0].data.author,
			books: books.sort((a, b) => b.data.totalChallenges - a.data.totalChallenges),
		},
	}));
}

const { authorName, books } = Astro.props;
const totalChallenges = books.reduce((sum: number, b: any) => sum + b.data.totalChallenges, 0);

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": `${Astro.site?.toString().replace(/\/$/, '') || 'https://merlin-1776.github.io'}/`
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Authors",
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": authorName,
		}
	]
};

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": authorName,
	"description": `${authorName} has ${books.length} banned or challenged book${books.length > 1 ? 's' : ''} with ${totalChallenges} total documented challenges.`
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Banned Books by ${authorName} | ${SITE_TITLE}`}
			description={`${authorName} has ${books.length} banned or challenged book${books.length > 1 ? 's' : ''} with ${totalChallenges} total documented challenges. See the full list.`}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href={`/`}>Home</a> →
				<span>{authorName}</span>
			</nav>

			<div class="author-header">
				<h1>Banned Books by <em>{authorName}</em></h1>
				<p class="author-stats">
					{books.length} banned book{books.length > 1 ? 's' : ''} · {totalChallenges} total challenges
				</p>
			</div>

			<div class="books-grid">
				{books.map((book: any) => (
					<BookCard
						title={book.data.title}
						slug={book.data.slug}
						author={book.data.author}
						totalChallenges={book.data.totalChallenges}
						banReasons={book.data.banReasons}
						description={book.data.description}
					/>
				))}
			</div>
		</main>
		<Footer />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.breadcrumb {
				font-size: 0.9rem;
				margin-bottom: 2em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: var(--accent);
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.author-header {
				margin-bottom: 2em;
			}
			.author-header h1 {
				font-size: 2.2rem;
				margin-bottom: 0.25em;
			}
			.author-header em {
				color: var(--accent);
			}
			.author-stats {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				margin: 0;
			}
			.books-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.5em;
			}
			@media (max-width: 720px) {
				.author-header h1 {
					font-size: 1.6rem;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
