---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BanReasonBadge from '../../components/BanReasonBadge.astro';
import BookSchema from '../../components/BookSchema.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

function slugifyAuthor(name: string) {
	return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

export async function getStaticPaths() {
	const books = await getCollection('books');
	return books.map((book) => ({
		params: { slug: book.data.slug },
		props: { book },
	}));
}

const { book } = Astro.props;
const { Content } = await render(book);
const {
	title,
	slug,
	author,
	isbn13,
	publisher,
	datePublished,
	description,
	banReasons,
	banLocations,
	totalChallenges,
	amazonUrl,
	bookshopUrl,
	capitalBooksUrl,
	buyLinks,
	series,
	seriesOrder,
	whyRead,
} = book.data;

const uniqueStates = [...new Set(banLocations.map((l) => l.state))];
const reasonsList = banReasons.join(', ');

// Get other books in same series
const allBooks = await getCollection('books');
const seriesBooks = series
	? allBooks
		.filter((b) => b.data.series === series && b.data.slug !== slug)
		.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0))
	: [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Yes, ${title} Is Banned! | ${SITE_TITLE}`}
			description={`${title} by ${author} has been banned or challenged ${totalChallenges} times. Find out why, where, and how to read it anyway.`}
		/>
		<BookSchema
			title={title}
			slug={slug}
			author={author}
			isbn13={isbn13}
			publisher={publisher}
			datePublished={datePublished}
			description={description}
			banReasons={banReasons}
			banLocations={banLocations}
			totalChallenges={totalChallenges}
		/>
	</head>
	<body>
		<Header />
		<div class="page-layout">
		<main>
			<nav class="breadcrumb">
				<a href={`/`}>Home</a> →
				<a href={`/books/`}>Books</a> →
				<span>{title}</span>
			</nav>

			<div class="book-header">
				<span class="banned-stamp">BANNED</span>
				{series && (
					<a href={`/series/${slugifyAuthor(series)}`} class="series-tag">📚 {series} Series</a>
				)}
				<h1>Yes, <em>{title}</em> Is Banned!</h1>
				<p class="book-meta">
					by <a href={`/authors/${slugifyAuthor(author)}`} class="author-link"><strong>{author}</strong></a>
					{publisher && <> · {publisher}</>}
					{datePublished && <> · {datePublished.split('-')[0]}</>}
				</p>
				{isbn13 && <p class="isbn">ISBN: {isbn13}</p>}
			</div>

			<div class="challenges-count">
				<span class="count-number">{totalChallenges}</span>
				<span class="count-label">documented challenges</span>
			</div>

			{whyRead && (
				<section class="why-read">
					<h2>📖 Why You Should Read This Book</h2>
					<p>{whyRead}</p>
				</section>
			)}

			<section class="book-content prose">
				<Content />
			</section>

			{seriesBooks.length > 0 && (
				<section class="series-nav">
					<h2>More in the {series} Series</h2>
					<div class="series-list">
						{seriesBooks.map((b) => (
							<a href={`/books/${b.data.slug}`} class="series-item">
								{b.data.seriesOrder && <span class="series-num">#{b.data.seriesOrder}</span>}
								<span class="series-title">{b.data.title}</span>
								<span class="series-challenges">{b.data.totalChallenges} challenges</span>
							</a>
						))}
					</div>
				</section>
			)}

			<section class="ban-reasons">
				<h2>Why Was It Banned?</h2>
				<div class="reasons-list">
					{banReasons.map((reason) => <BanReasonBadge reason={reason} />)}
				</div>
			</section>

			<section class="ban-locations">
				<h2>Where Was It Banned?</h2>
				<div class="locations-grid">
					{banLocations.map((loc) => {
						const stateSlug = loc.state.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
						return (
							<div class="location-item">
								<a href={`/states/${stateSlug}`} class="location-state">{loc.state}</a>
								{loc.district && <span class="location-district">{loc.district}</span>}
								<span class="location-meta">
									{loc.year && <span class="location-year">{loc.year}</span>}
									{loc.sourceUrl && (
										<a href={loc.sourceUrl} target="_blank" rel="noopener noreferrer" class="source-link" title="Read news coverage">
											📰
										</a>
									)}
								</span>
							</div>
						);
					})}
				</div>
			</section>

			<section class="buy-section">
				<h2>Read It Anyway</h2>
				<p>The best response to a book ban is reading the book. Here's where to get it:</p>

				{/* Multiple editions/formats */}
				{buyLinks && buyLinks.length > 0 && (
					<div class="editions">
						{buyLinks.map((edition) => (
							<div class="edition-group">
								<h3 class="edition-label">{edition.label}</h3>
								<div class="buy-options">
									{edition.capitalBooks && (
										<a href={edition.capitalBooks} target="_blank" rel="noopener noreferrer" class="buy-btn capital-btn">Capital Books</a>
									)}
									{edition.bookshop && (
										<a href={edition.bookshop} target="_blank" rel="noopener noreferrer" class="buy-btn bookshop-btn">Bookshop.org</a>
									)}
									{edition.amazon && (
										<a href={edition.amazon} target="_blank" rel="noopener noreferrer" class="buy-btn amazon-btn">Amazon</a>
									)}
								</div>
							</div>
						))}
					</div>
				)}

				{/* Legacy single links (fallback) */}
				{(!buyLinks || buyLinks.length === 0) && (
					<div class="buy-options">
						{capitalBooksUrl && (
							<div class="buy-option capital">
								<a href={capitalBooksUrl} target="_blank" rel="noopener noreferrer" class="buy-btn capital-btn">
									Buy from Capital Books
								</a>
								<p class="buy-pitch">Support the bookstore that built this site. You won't get your book overnight, but we'll make 30%.</p>
							</div>
						)}
						{!capitalBooksUrl && (
							<div class="buy-option capital">
								<a href="https://capitalbooksonk.com" target="_blank" rel="noopener noreferrer" class="buy-btn capital-btn">
									Buy from Capital Books
								</a>
								<p class="buy-pitch">Support the bookstore that built this site. You won't get your book overnight, but we'll make 30%.</p>
							</div>
						)}
						{bookshopUrl && (
							<div class="buy-option bookshop">
								<a href={bookshopUrl} target="_blank" rel="noopener noreferrer" class="buy-btn bookshop-btn">
									Buy on Bookshop.org
								</a>
								<p class="buy-pitch">Support indie bookstores. Pick one or help them all. (We make 10%.)</p>
							</div>
						)}
						{amazonUrl && (
							<div class="buy-option amazon">
								<a href={amazonUrl} target="_blank" rel="noopener noreferrer" class="buy-btn amazon-btn">
									Buy on Amazon
								</a>
								<p class="buy-pitch">We know. They're huge, cheap, own a rocket ship, and you'll probably get it overnight. (We get 4%.)</p>
							</div>
						)}
					</div>
				)}
			</section>

			<section class="faq">
				<h2>Frequently Asked Questions</h2>

				<div class="faq-item">
					<h3>Is {title} banned?</h3>
					<p>Yes, {title} by {author} has been banned or challenged in {totalChallenges} documented instances across {uniqueStates.length} states in the United States, including {uniqueStates.slice(0, 5).join(', ')}. It remains one of the most frequently challenged books in America.</p>
				</div>

				<div class="faq-item">
					<h3>Why was {title} banned?</h3>
					<p>{title} has been challenged and banned for the following reasons: {reasonsList}. These challenges have come from school boards, libraries, and parent groups seeking to restrict access to the book.</p>
				</div>

				<div class="faq-item">
					<h3>Where is {title} banned?</h3>
					<p>As of 2025, {title} has been banned or challenged in {uniqueStates.join(', ')}. Notable bans include {banLocations.slice(0, 3).map((l) => `${l.district || l.state} (${l.year || 'ongoing'})`).join(', ')}.</p>
				</div>
			</section>
		</main>
		<Sidebar />
		</div>
		<Footer />

		<style>
			.page-layout {
				display: flex;
				gap: 2em;
				max-width: 1280px;
				margin: 0 auto;
				padding: 1em 1em 2em;
			}
			main {
				flex: 1;
				min-width: 0;
				width: auto;
				max-width: none;
				padding: 0 !important;
				margin: 0;
			}
			.breadcrumb {
				margin-bottom: 1em;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.book-header {
				margin-bottom: 1.5em;
			}
			.banned-stamp {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.85rem;
				font-weight: 800;
				padding: 0.3em 1em;
				border-radius: 4px;
				letter-spacing: 0.15em;
				margin-bottom: 0.75em;
			}
			.series-tag {
				display: inline-block;
				background: #1e3a5f;
				color: #fff;
				font-size: 0.85rem;
				font-weight: 600;
				padding: 0.3em 1em;
				border-radius: 4px;
				margin-bottom: 0.75em;
				margin-left: 0.5em;
				text-decoration: none;
				transition: background 0.2s;
			}
			.series-tag:hover {
				background: #2d5a87;
			}
			h1 {
				font-size: 2.5em;
				line-height: 1.15;
				margin-bottom: 0.3em;
			}
			h1 em {
				font-style: italic;
			}
			.book-meta {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.author-link {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s;
			}
			.author-link:hover {
				border-bottom-color: var(--accent);
			}
			.isbn {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-top: 0.25em;
			}
			.challenges-count {
				display: flex;
				align-items: baseline;
				gap: 0.5em;
				background: #111;
				color: #fff;
				padding: 1em 1.5em;
				border-radius: 8px;
				margin-bottom: 2em;
			}
			.count-number {
				font-size: 3em;
				font-weight: 800;
				color: var(--accent);
				line-height: 1;
			}
			.count-label {
				font-size: 1.1rem;
				opacity: 0.8;
			}
			.book-content {
				margin-bottom: 2em;
			}
			.ban-reasons {
				margin-bottom: 2em;
			}
			.ban-reasons h2 {
				font-size: 1.8em;
				margin-bottom: 0.75em;
			}
			.reasons-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.ban-locations {
				margin-bottom: 2em;
			}
			.ban-locations h2 {
				font-size: 1.8em;
				margin-bottom: 0.75em;
			}
			.locations-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 0.75em;
			}
			.location-item {
				display: flex;
				flex-direction: column;
				padding: 0.75em 1em;
				background: #fff;
				border: 2px solid rgb(var(--gray-light));
				border-radius: 8px;
				border-left: 4px solid var(--accent);
			}
			.location-state {
				font-weight: 700;
				font-size: 1rem;
				color: var(--accent);
				text-decoration: none;
				transition: opacity 0.2s;
			}
			.location-state:hover {
				opacity: 0.8;
				text-decoration: underline;
			}
			.location-district {
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.location-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
			}
			.location-year {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				font-weight: 600;
			}
			.source-link {
				font-size: 0.9rem;
				text-decoration: none;
				transition: transform 0.2s;
				display: inline-block;
			}
			.source-link:hover {
				transform: scale(1.2);
			}
			.buy-section {
				background: #111;
				color: #fff;
				padding: 2em;
				border-radius: 12px;
				margin-bottom: 2em;
			}
			.buy-section h2 {
				color: #fff;
				font-size: 1.8em;
				margin-bottom: 0.3em;
				text-align: center;
			}
			.buy-section > p {
				opacity: 0.8;
				margin-bottom: 1.5em;
				text-align: center;
			}
			.buy-options {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 1.5em;
			}
			.buy-option {
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 10px;
				padding: 1.5em;
				text-align: center;
			}
			.buy-option .buy-pitch {
				font-size: 0.85rem;
				opacity: 0.7;
				margin: 0.75em 0 0 0;
				line-height: 1.5;
				font-style: italic;
			}
			.buy-btn {
				display: inline-block;
				padding: 0.75em 2em;
				border-radius: 8px;
				font-weight: 700;
				text-decoration: none;
				font-size: 1rem;
				transition: all 0.2s;
				width: 100%;
				box-sizing: border-box;
			}
			.capital-btn {
				background: #16a34a;
				color: #fff;
			}
			.capital-btn:hover {
				background: #15803d;
				color: #fff;
			}
			.bookshop-btn {
				background: var(--accent);
				color: #fff;
			}
			.bookshop-btn:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.amazon-btn {
				background: #f59e0b;
				color: #111;
			}
			.amazon-btn:hover {
				background: #d97706;
			}
			@media (max-width: 960px) {
				.page-layout {
					flex-direction: column;
				}
			}
			@media (max-width: 720px) {
				.buy-options {
					grid-template-columns: 1fr;
				}
			}
			.why-read {
				background: linear-gradient(135deg, #1e3a5f, #2d5a87);
				color: #fff;
				padding: 2em;
				border-radius: 12px;
				margin-bottom: 2em;
			}
			.why-read h2 {
				color: #fff;
				font-size: 1.5em;
				margin-bottom: 0.5em;
			}
			.why-read p {
				font-size: 1.05rem;
				line-height: 1.7;
				opacity: 0.95;
			}
			.series-nav {
				margin-bottom: 2em;
			}
			.series-nav h2 {
				font-size: 1.5em;
				margin-bottom: 0.75em;
			}
			.series-list {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 0.75em;
			}
			.series-item {
				display: flex;
				flex-direction: column;
				padding: 0.75em 1em;
				background: #fff;
				border: 2px solid rgb(var(--gray-light));
				border-radius: 8px;
				text-decoration: none;
				transition: border-color 0.2s;
			}
			.series-item:hover {
				border-color: var(--accent);
			}
			.series-num {
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
			}
			.series-title {
				font-weight: 600;
				color: #111;
			}
			.series-challenges {
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			.editions {
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.edition-group {
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 10px;
				padding: 1.25em;
			}
			.edition-label {
				color: #fff;
				font-size: 1rem;
				margin-bottom: 0.75em;
			}
			.edition-group .buy-options {
				display: flex;
				gap: 0.75em;
				flex-wrap: wrap;
			}
			.edition-group .buy-btn {
				flex: 1;
				min-width: 140px;
				text-align: center;
			}
			.faq {
				margin-bottom: 2em;
			}
			.faq h2 {
				font-size: 1.8em;
				margin-bottom: 1em;
			}
			.faq-item {
				background: #fff;
				border: 2px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1.5em;
				margin-bottom: 1em;
			}
			.faq-item h3 {
				font-size: 1.1rem;
				margin-bottom: 0.5em;
				color: var(--accent-dark);
			}
			.faq-item p {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.6;
			}
			@media (max-width: 720px) {
				h1 {
					font-size: 1.8em;
				}
				.count-number {
					font-size: 2em;
				}
				.locations-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
