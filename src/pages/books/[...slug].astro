---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BanReasonBadge from '../../components/BanReasonBadge.astro';
import BookSchema from '../../components/BookSchema.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

function slugifyAuthor(name: string) {
	return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

export async function getStaticPaths() {
	const books = await getCollection('books');
	return books.map((book) => ({
		params: { slug: book.data.slug },
		props: { book },
	}));
}

const { book } = Astro.props;
const { Content } = await render(book);
const {
	title,
	slug,
	author,
	isbn13,
	publisher,
	datePublished,
	description,
	banReasons,
	banLocations,
	totalChallenges,
	amazonUrl,
	bookshopUrl,
	capitalBooksUrl,
} = book.data;

const uniqueStates = [...new Set(banLocations.map((l) => l.state))];
const reasonsList = banReasons.join(', ');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Yes, ${title} Is Banned! | ${SITE_TITLE}`}
			description={`${title} by ${author} has been banned or challenged ${totalChallenges} times. Find out why, where, and how to read it anyway.`}
		/>
		<BookSchema
			title={title}
			slug={slug}
			author={author}
			isbn13={isbn13}
			publisher={publisher}
			datePublished={datePublished}
			description={description}
			banReasons={banReasons}
			banLocations={banLocations}
			totalChallenges={totalChallenges}
		/>
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href={`${import.meta.env.BASE_URL}/`}>Home</a> →
				<a href={`${import.meta.env.BASE_URL}/books/`}>Books</a> →
				<span>{title}</span>
			</nav>

			<div class="book-header">
				<span class="banned-stamp">BANNED</span>
				<h1>Yes, <em>{title}</em> Is Banned!</h1>
				<p class="book-meta">
					by <a href={`${import.meta.env.BASE_URL}/authors/${slugifyAuthor(author)}`} class="author-link"><strong>{author}</strong></a>
					{publisher && <> · {publisher}</>}
					{datePublished && <> · {datePublished.split('-')[0]}</>}
				</p>
				{isbn13 && <p class="isbn">ISBN: {isbn13}</p>}
			</div>

			<div class="challenges-count">
				<span class="count-number">{totalChallenges}</span>
				<span class="count-label">documented challenges</span>
			</div>

			<section class="book-content prose">
				<Content />
			</section>

			<section class="ban-reasons">
				<h2>Why Was It Banned?</h2>
				<div class="reasons-list">
					{banReasons.map((reason) => <BanReasonBadge reason={reason} />)}
				</div>
			</section>

			<section class="ban-locations">
				<h2>Where Was It Banned?</h2>
				<div class="locations-grid">
					{banLocations.map((loc) => (
						<div class="location-item">
							<span class="location-state">{loc.state}</span>
							{loc.district && <span class="location-district">{loc.district}</span>}
							{loc.year && <span class="location-year">{loc.year}</span>}
						</div>
					))}
				</div>
			</section>

			<section class="buy-section">
				<h2>Read It Anyway</h2>
				<p>The best response to a book ban is reading the book. Here's where to get it:</p>
				<div class="buy-options">
					{capitalBooksUrl && (
						<div class="buy-option capital">
							<a href={capitalBooksUrl} target="_blank" rel="noopener noreferrer" class="buy-btn capital-btn">
								Buy from Capital Books
							</a>
							<p class="buy-pitch">Support the bookstore that built this site. You won't get your book overnight, but we'll make 30%.</p>
						</div>
					)}
					{!capitalBooksUrl && (
						<div class="buy-option capital">
							<a href="https://www.capitalbooksonk.com" target="_blank" rel="noopener noreferrer" class="buy-btn capital-btn">
								Buy from Capital Books
							</a>
							<p class="buy-pitch">Support the bookstore that built this site. You won't get your book overnight, but we'll make 30%.</p>
						</div>
					)}
					{bookshopUrl && (
						<div class="buy-option bookshop">
							<a href={bookshopUrl} target="_blank" rel="noopener noreferrer" class="buy-btn bookshop-btn">
								Buy on Bookshop.org
							</a>
							<p class="buy-pitch">Support indie bookstores. Pick one or help them all. (We make 10%.)</p>
						</div>
					)}
					{amazonUrl && (
						<div class="buy-option amazon">
							<a href={amazonUrl} target="_blank" rel="noopener noreferrer" class="buy-btn amazon-btn">
								Buy on Amazon
							</a>
							<p class="buy-pitch">Yeah, we know. They're cheap, easy, and you already have an account. (We make 4%.)</p>
						</div>
					)}
				</div>
			</section>

			<section class="faq">
				<h2>Frequently Asked Questions</h2>

				<div class="faq-item">
					<h3>Is {title} banned?</h3>
					<p>Yes, {title} by {author} has been banned or challenged in {totalChallenges} documented instances across {uniqueStates.length} states in the United States, including {uniqueStates.slice(0, 5).join(', ')}. It remains one of the most frequently challenged books in America.</p>
				</div>

				<div class="faq-item">
					<h3>Why was {title} banned?</h3>
					<p>{title} has been challenged and banned for the following reasons: {reasonsList}. These challenges have come from school boards, libraries, and parent groups seeking to restrict access to the book.</p>
				</div>

				<div class="faq-item">
					<h3>Where is {title} banned?</h3>
					<p>As of 2025, {title} has been banned or challenged in {uniqueStates.join(', ')}. Notable bans include {banLocations.slice(0, 3).map((l) => `${l.district || l.state} (${l.year || 'ongoing'})`).join(', ')}.</p>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			.breadcrumb {
				margin-bottom: 2em;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.book-header {
				margin-bottom: 1.5em;
			}
			.banned-stamp {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				font-size: 0.85rem;
				font-weight: 800;
				padding: 0.3em 1em;
				border-radius: 4px;
				letter-spacing: 0.15em;
				margin-bottom: 0.75em;
			}
			h1 {
				font-size: 2.5em;
				line-height: 1.15;
				margin-bottom: 0.3em;
			}
			h1 em {
				font-style: italic;
			}
			.book-meta {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				margin: 0;
			}
			.author-link {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: border-color 0.2s;
			}
			.author-link:hover {
				border-bottom-color: var(--accent);
			}
			.isbn {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin-top: 0.25em;
			}
			.challenges-count {
				display: flex;
				align-items: baseline;
				gap: 0.5em;
				background: #111;
				color: #fff;
				padding: 1em 1.5em;
				border-radius: 8px;
				margin-bottom: 2em;
			}
			.count-number {
				font-size: 3em;
				font-weight: 800;
				color: var(--accent);
				line-height: 1;
			}
			.count-label {
				font-size: 1.1rem;
				opacity: 0.8;
			}
			.book-content {
				margin-bottom: 2em;
			}
			.ban-reasons {
				margin-bottom: 2em;
			}
			.ban-reasons h2 {
				font-size: 1.8em;
				margin-bottom: 0.75em;
			}
			.reasons-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.ban-locations {
				margin-bottom: 2em;
			}
			.ban-locations h2 {
				font-size: 1.8em;
				margin-bottom: 0.75em;
			}
			.locations-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 0.75em;
			}
			.location-item {
				display: flex;
				flex-direction: column;
				padding: 0.75em 1em;
				background: #fff;
				border: 2px solid rgb(var(--gray-light));
				border-radius: 8px;
				border-left: 4px solid var(--accent);
			}
			.location-state {
				font-weight: 700;
				font-size: 1rem;
			}
			.location-district {
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.location-year {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				font-weight: 600;
			}
			.buy-section {
				background: #111;
				color: #fff;
				padding: 2em;
				border-radius: 12px;
				margin-bottom: 2em;
			}
			.buy-section h2 {
				color: #fff;
				font-size: 1.8em;
				margin-bottom: 0.3em;
				text-align: center;
			}
			.buy-section > p {
				opacity: 0.8;
				margin-bottom: 1.5em;
				text-align: center;
			}
			.buy-options {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 1.5em;
			}
			.buy-option {
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 10px;
				padding: 1.5em;
				text-align: center;
			}
			.buy-option .buy-pitch {
				font-size: 0.85rem;
				opacity: 0.7;
				margin: 0.75em 0 0 0;
				line-height: 1.5;
				font-style: italic;
			}
			.buy-btn {
				display: inline-block;
				padding: 0.75em 2em;
				border-radius: 8px;
				font-weight: 700;
				text-decoration: none;
				font-size: 1rem;
				transition: all 0.2s;
				width: 100%;
				box-sizing: border-box;
			}
			.capital-btn {
				background: #16a34a;
				color: #fff;
			}
			.capital-btn:hover {
				background: #15803d;
				color: #fff;
			}
			.bookshop-btn {
				background: var(--accent);
				color: #fff;
			}
			.bookshop-btn:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.amazon-btn {
				background: #f59e0b;
				color: #111;
			}
			.amazon-btn:hover {
				background: #d97706;
			}
			@media (max-width: 720px) {
				.buy-options {
					grid-template-columns: 1fr;
				}
			}
			.faq {
				margin-bottom: 2em;
			}
			.faq h2 {
				font-size: 1.8em;
				margin-bottom: 1em;
			}
			.faq-item {
				background: #fff;
				border: 2px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1.5em;
				margin-bottom: 1em;
			}
			.faq-item h3 {
				font-size: 1.1rem;
				margin-bottom: 0.5em;
				color: var(--accent-dark);
			}
			.faq-item p {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.6;
			}
			@media (max-width: 720px) {
				h1 {
					font-size: 1.8em;
				}
				.count-number {
					font-size: 2em;
				}
				.locations-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
