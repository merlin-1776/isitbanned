---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookCard from '../../components/BookCard.astro';
import BanReasonBadge from '../../components/BanReasonBadge.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const books = await getCollection('books');
	const reasonMap = new Map<string, { reason: string; books: typeof books }>();

	for (const book of books) {
		for (const reason of book.data.banReasons) {
			const slug = reason.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
			if (!reasonMap.has(slug)) {
				reasonMap.set(slug, { reason, books: [] });
			}
			reasonMap.get(slug)!.books.push(book);
		}
	}

	return Array.from(reasonMap.entries()).map(([slug, { reason, books }]) => ({
		params: { reason: slug },
		props: {
			reasonName: reason,
			books: books.sort((a, b) => b.data.totalChallenges - a.data.totalChallenges),
		},
	}));
}

const { reasonName, books } = Astro.props;
const totalChallenges = books.reduce((sum: number, b: any) => sum + b.data.totalChallenges, 0);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://merlin-1776.github.io';
const basePath = '';

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": `${siteUrl}${basePath}/`
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Ban Reasons",
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": reasonName,
		}
	]
};

const collectionSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": `Books Banned for ${reasonName}`,
	"description": `${books.length} books have been banned or challenged for ${reasonName.toLowerCase()}. Browse the full list.`,
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Books Banned for ${reasonName} | ${SITE_TITLE}`}
			description={`${books.length} books have been banned or challenged for ${reasonName.toLowerCase()} with ${totalChallenges} total challenges. Browse the full list.`}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href={`/`}>Home</a> →
				<span>{reasonName}</span>
			</nav>

			<div class="reason-header">
				<BanReasonBadge reason={reasonName} linked={false} />
				<h1>Books Banned for {reasonName}</h1>
				<p class="reason-stats">
					{books.length} book{books.length > 1 ? 's' : ''} · {totalChallenges} total challenges
				</p>
			</div>

			<div class="books-grid">
				{books.map((book: any) => (
					<BookCard
						title={book.data.title}
						slug={book.data.slug}
						author={book.data.author}
						totalChallenges={book.data.totalChallenges}
						banReasons={book.data.banReasons}
						description={book.data.description}
					/>
				))}
			</div>
		</main>
		<Footer />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.breadcrumb {
				font-size: 0.9rem;
				margin-bottom: 2em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: var(--accent);
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.reason-header {
				margin-bottom: 2em;
			}
			.reason-header h1 {
				font-size: 2.2rem;
				margin: 0.5em 0 0.25em 0;
			}
			.reason-stats {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				margin: 0;
			}
			.books-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.5em;
			}
			@media (max-width: 720px) {
				.reason-header h1 {
					font-size: 1.6rem;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
