---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookCard from '../../components/BookCard.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const books = await getCollection('books');
	const stateMap = new Map<string, { state: string; books: Set<string>; bookData: typeof books }>();

	for (const book of books) {
		for (const loc of book.data.banLocations) {
			const slug = loc.state.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
			if (!stateMap.has(slug)) {
				stateMap.set(slug, { state: loc.state, books: new Set(), bookData: [] });
			}
			const entry = stateMap.get(slug)!;
			if (!entry.books.has(book.data.slug)) {
				entry.books.add(book.data.slug);
				entry.bookData.push(book);
			}
		}
	}

	return Array.from(stateMap.entries()).map(([slug, { state, bookData }]) => ({
		params: { state: slug },
		props: {
			stateName: state,
			books: bookData.sort((a, b) => b.data.totalChallenges - a.data.totalChallenges),
		},
	}));
}

const { stateName, books } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://merlin-1776.github.io';
const basePath = '';

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": `${siteUrl}${basePath}/`
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "States",
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": stateName,
		}
	]
};

const collectionSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": `Books Banned in ${stateName}`,
	"description": `${books.length} books have been banned or challenged in ${stateName}. Browse the full list.`,
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Books Banned in ${stateName} | ${SITE_TITLE}`}
			description={`${books.length} books have been banned or challenged in ${stateName}. See which books are restricted and why.`}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href={`/`}>Home</a> →
				<span>{stateName}</span>
			</nav>

			<div class="state-header">
				<h1>Books Banned in {stateName}</h1>
				<p class="state-stats">
					{books.length} banned book{books.length > 1 ? 's' : ''}
				</p>
			</div>

			<div class="books-grid">
				{books.map((book: any) => (
					<BookCard
						title={book.data.title}
						slug={book.data.slug}
						author={book.data.author}
						totalChallenges={book.data.totalChallenges}
						banReasons={book.data.banReasons}
						description={book.data.description}
					/>
				))}
			</div>
		</main>
		<Footer />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.breadcrumb {
				font-size: 0.9rem;
				margin-bottom: 2em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: var(--accent);
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.state-header {
				margin-bottom: 2em;
			}
			.state-header h1 {
				font-size: 2.2rem;
				margin-bottom: 0.25em;
			}
			.state-stats {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				margin: 0;
			}
			.books-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.5em;
			}
			@media (max-width: 720px) {
				.state-header h1 {
					font-size: 1.6rem;
				}
				.books-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
