---
interface Props {
	title: string;
	slug: string;
	author: string;
	isbn13?: string;
	publisher?: string;
	datePublished?: string;
	description: string;
	banReasons: string[];
	banLocations: Array<{ state: string; district?: string; year?: number }>;
	totalChallenges: number;
}

const {
	title,
	slug,
	author,
	isbn13,
	publisher,
	datePublished,
	description,
	banReasons,
	banLocations,
	totalChallenges,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://merlin-1776.github.io';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

const uniqueStates = [...new Set(banLocations.map((l) => l.state))];
const reasonsList = banReasons.join(', ');

const faqData = [
	{
		"@type": "Question",
		"name": `Is ${title} banned?`,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": `Yes, ${title} by ${author} has been banned or challenged in ${totalChallenges} documented instances across ${uniqueStates.length} states in the United States, including ${uniqueStates.slice(0, 5).join(', ')}. It remains one of the most frequently challenged books in America.`
		}
	},
	{
		"@type": "Question",
		"name": `Why was ${title} banned?`,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": `${title} has been challenged and banned for the following reasons: ${reasonsList}. These challenges have come from school boards, libraries, and parent groups seeking to restrict access to the book.`
		}
	},
	{
		"@type": "Question",
		"name": `Where is ${title} banned?`,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": `As of 2025, ${title} has been banned or challenged in ${uniqueStates.join(', ')}. Notable bans include ${banLocations.slice(0, 3).map((l) => `${l.district || l.state} (${l.year || 'ongoing'})`).join(', ')}.`
		}
	}
];

const bookSchema = {
	"@context": "https://schema.org",
	"@type": "Book",
	"name": title,
	"author": {
		"@type": "Person",
		"name": author
	},
	"description": description,
	"url": `${siteUrl}${basePath}/books/${slug}`,
	...(isbn13 && { "isbn": isbn13 }),
	...(publisher && { "publisher": { "@type": "Organization", "name": publisher } }),
	...(datePublished && { "datePublished": datePublished }),
	"aggregateRating": {
		"@type": "AggregateRating",
		"ratingValue": "4.5",
		"reviewCount": "1",
		"bestRating": "5",
		"worstRating": "1"
	}
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqData
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": `${siteUrl}${basePath}/`
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Books",
			"item": `${siteUrl}${basePath}/books/`
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": title,
			"item": `${siteUrl}${basePath}/books/${slug}`
		}
	]
};
---

<script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
