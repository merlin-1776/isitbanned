---
import BanReasonBadge from './BanReasonBadge.astro';

interface Props {
	title: string;
	slug: string;
	author: string;
	totalChallenges: number;
	banReasons: string[];
	description: string;
}

const { title, slug, author, totalChallenges, banReasons, description } = Astro.props;
const topReasons = banReasons.slice(0, 3);
---

<a href={`${import.meta.env.BASE_URL}books/${slug}`} class="book-card">
	<div class="card-content">
		<div class="card-header">
			<span class="banned-tag">BANNED</span>
			<span class="challenges">{totalChallenges} challenges</span>
		</div>
		<h3>{title}</h3>
		<p class="author">by {author}</p>
		<p class="description">{description.slice(0, 120)}...</p>
		<div class="reasons">
			{topReasons.map((reason) => <BanReasonBadge reason={reason} />)}
		</div>
	</div>
</a>

<style>
	.book-card {
		display: block;
		background: #fff;
		border: 2px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.5em;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s ease;
		position: relative;
		overflow: hidden;
	}
	.book-card:hover {
		border-color: var(--accent);
		box-shadow: 0 8px 24px rgba(220, 38, 38, 0.15);
		transform: translateY(-2px);
	}
	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.75em;
	}
	.banned-tag {
		background: var(--accent);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 800;
		padding: 0.2em 0.6em;
		border-radius: 4px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.challenges {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		font-weight: 600;
	}
	h3 {
		margin: 0 0 0.25em 0;
		font-size: 1.25rem;
		color: rgb(var(--black));
		line-height: 1.3;
	}
	.author {
		margin: 0 0 0.5em 0;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		font-style: italic;
	}
	.description {
		font-size: 0.85rem;
		color: rgb(var(--gray-dark));
		margin: 0 0 1em 0;
		line-height: 1.5;
	}
	.reasons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}
</style>
