---
interface Props {
	reason: string;
	linked?: boolean;
}

const { reason, linked = true } = Astro.props;

const colorMap: Record<string, string> = {
	'Sexual Content': '#dc2626',
	'LGBTQ+ Themes': '#7c3aed',
	'Racial Content': '#d97706',
	'Violence': '#b91c1c',
	'Religious Objections': '#0369a1',
	'Political Content': '#4338ca',
	'Language': '#c2410c',
	'Drug/Alcohol Use': '#15803d',
	'Age Inappropriateness': '#be185d',
};

const color = colorMap[reason] || '#6b7280';
const slug = reason.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const href = `${import.meta.env.BASE_URL}/reasons/${slug}`;
---

{linked ? (
	<a href={href} class="ban-reason-badge" style={`--badge-color: ${color}`}>
		{reason}
	</a>
) : (
	<span class="ban-reason-badge" style={`--badge-color: ${color}`}>
		{reason}
	</span>
)}

<style>
	.ban-reason-badge {
		display: inline-block;
		padding: 0.25em 0.75em;
		border-radius: 9999px;
		font-size: 0.8rem;
		font-weight: 700;
		color: #fff;
		background-color: var(--badge-color);
		white-space: nowrap;
		line-height: 1.4;
		text-decoration: none;
		transition: opacity 0.2s, transform 0.2s;
	}
	a.ban-reason-badge:hover {
		opacity: 0.85;
		transform: scale(1.05);
		color: #fff;
	}
</style>
